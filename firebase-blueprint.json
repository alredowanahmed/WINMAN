{
  "entities": {
    "Ad": {
      "title": "Ad",
      "description": "Advertisement data to be displayed in the app",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the ad" },
        "description": { "type": "string", "description": "The description of the ad" },
        "link": { "type": "string", "description": "The URL the ad points to" },
        "adScript": { "type": "string", "description": "Optional Google AdSense or other ad script code" },
        "active": { "type": "boolean", "description": "Whether the ad is currently active" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the ad was created" }
      },
      "required": ["title", "description", "link", "active"]
    },
    "UserStat": {
      "title": "UserStat",
      "description": "Statistics for a specific user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "lastUsed": { "type": "string", "format": "date-time", "description": "The last time the user used the app" },
        "usageCount": { "type": "number", "description": "How many times the user has used the app" }
      },
      "required": ["uid", "usageCount"]
    }
  },
  "firestore": {
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Collection of advertisements"
    },
    "/user_stats/{userId}": {
      "schema": "UserStat",
      "description": "Collection of user statistics"
    }
  }
}
